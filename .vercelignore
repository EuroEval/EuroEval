# Keep upload payload small and avoid Vercel's 100 MB per-file limit
# (the .git packfile alone is >100 MB).

.git
.github
.venv
.euroeval_cache
.scandeval_cache
.pytest_cache
.ruff_cache
.mypy_cache
node_modules

# Local maintainer artifacts (large, never needed at runtime).
results.tar.gz
new_results.jsonl
ucloud*_results.jsonl
*outputs.json

# Source directories not consumed by the Vite build. `src/scripts`,
# `src/frontend`, and `src/euroeval` are all needed remotely (the api-reference
# Vite plugin walks the Python package), so only `src/leaderboards` is dropped.
src/leaderboards
tests
docs
site
__pycache__

# Dotfiles & misc
.env*
.vercel
.DS_Store
*.log
