# Keep upload payload small and avoid Vercel's 100 MB per-file limit
# (the .git packfile alone is >100 MB).

.git
.github
.venv
.euroeval_cache
.scandeval_cache
.pytest_cache
.ruff_cache
.mypy_cache
node_modules

# Local maintainer artifacts (large, never needed at runtime).
results.tar.gz
new_results.jsonl
ucloud*_results.jsonl
*outputs.json

# Python sources & docs — Vercel only needs `api/`, `dist/`, `vercel.json`,
# plus `src/scripts/` for the Vite plugins imported from vite.config.js.
src
!src/scripts
tests
docs
site
__pycache__

# Dotfiles & misc
.env*
.vercel
.DS_Store
*.log
